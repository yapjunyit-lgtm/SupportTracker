@model List<SupportTracker.Models.User>

@{
    ViewData["Title"] = "Users";
}

<h1 class="h2 mb-4">Users</h1>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Department</th>
                <th>Assigned Tickets</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td class="fw-medium">@user.FullName</td>
                    <td>@user.Email</td>
                    <td>@user.Department</td>
                    <td>
                        @if (user.AssignedTickets.Any())
                        {
                            var open = user.AssignedTickets.Count(t => t.Status == SupportTracker.Models.TicketStatus.Open);
                            var inProgress = user.AssignedTickets.Count(t => t.Status == SupportTracker.Models.TicketStatus.InProgress);
                            <span>@user.AssignedTickets.Count total</span>
                            @if (open > 0)
                            {
                                <span class="badge bg-danger ms-1">@open open</span>
                            }
                            @if (inProgress > 0)
                            {
                                <span class="badge bg-warning text-dark ms-1">@inProgress in progress</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">None</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
