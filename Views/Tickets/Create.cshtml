@model SupportTracker.Models.Ticket

@{
    ViewData["Title"] = "Create Ticket";
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr; Back to Tickets</a>
</div>

<h1 class="h2 mb-4">Create Ticket</h1>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" placeholder="Brief summary of the issue" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="5" placeholder="Detailed description of the issue"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Priority" class="form-label"></label>
                <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<SupportTracker.Models.TicketPriority>()"></select>
                <span asp-validation-for="Priority" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="AssignedToId" class="form-label">Assign To</label>
                <select asp-for="AssignedToId" class="form-select" asp-items="ViewBag.UserList">
                    <option value="">— Unassigned —</option>
                </select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create Ticket</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
