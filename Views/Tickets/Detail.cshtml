@model SupportTracker.Models.Ticket

@{
    ViewData["Title"] = $"Ticket #{Model.Id}";
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr; Back to Tickets</a>
</div>

<div class="d-flex justify-content-between align-items-start mb-3">
    <h1 class="h2">@Model.Title</h1>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit Ticket</a>
</div>

<div class="row mb-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header fw-medium">Description</div>
            <div class="card-body">
                <p class="card-text" style="white-space: pre-wrap;">@Model.Description</p>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-medium">Comments (@Model.Comments.Count)</span>
            </div>
            <div class="card-body">
                @if (!Model.Comments.Any())
                {
                    <p class="text-muted mb-0">No comments yet.</p>
                }
                else
                {
                    @foreach (var comment in Model.Comments)
                    {
                        <div class="border-bottom pb-3 mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <strong>@comment.AuthorName</strong>
                                <small class="text-muted">@comment.CreatedAt.ToString("MMM dd, yyyy HH:mm")</small>
                            </div>
                            <p class="mb-0" style="white-space: pre-wrap;">@comment.Content</p>
                        </div>
                    }
                }

                <form asp-controller="Tickets" asp-action="AddComment" method="post" class="mt-3">
                    <input type="hidden" name="TicketId" value="@Model.Id" />
                    <div class="mb-2">
                        <label class="form-label">Add a comment</label>
                        <textarea name="Content" class="form-control" rows="2" required></textarea>
                    </div>
                    <div class="row g-2">
                        <div class="col-sm-8">
                            <input type="text" name="AuthorName" class="form-control" placeholder="Your name" required maxlength="100" />
                        </div>
                        <div class="col-sm-4 text-end">
                            <button type="submit" class="btn btn-primary">Post Comment</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header fw-medium">Details</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Status</dt>
                    <dd class="col-sm-7">
                        <span class="badge @StatusBadge(Model.Status)">@Model.Status</span>
                    </dd>

                    <dt class="col-sm-5">Priority</dt>
                    <dd class="col-sm-7">
                        <span class="badge @PriorityBadge(Model.Priority)">@Model.Priority</span>
                    </dd>

                    <dt class="col-sm-5">Assigned To</dt>
                    <dd class="col-sm-7">@(Model.AssignedTo?.FullName ?? "—")</dd>

                    <dt class="col-sm-5">Created</dt>
                    <dd class="col-sm-7">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</dd>

                    <dt class="col-sm-5">Updated</dt>
                    <dd class="col-sm-7">@Model.UpdatedAt.ToString("MMM dd, yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

@functions {
    string StatusBadge(SupportTracker.Models.TicketStatus status) => status switch
    {
        SupportTracker.Models.TicketStatus.Open => "bg-danger",
        SupportTracker.Models.TicketStatus.InProgress => "bg-warning text-dark",
        SupportTracker.Models.TicketStatus.Resolved => "bg-success",
        SupportTracker.Models.TicketStatus.Closed => "bg-secondary",
        _ => "bg-light text-dark"
    };

    string PriorityBadge(SupportTracker.Models.TicketPriority priority) => priority switch
    {
        SupportTracker.Models.TicketPriority.Critical => "bg-dark",
        SupportTracker.Models.TicketPriority.High => "bg-danger",
        SupportTracker.Models.TicketPriority.Medium => "bg-info text-dark",
        SupportTracker.Models.TicketPriority.Low => "bg-light text-dark",
        _ => "bg-light text-dark"
    };
}
